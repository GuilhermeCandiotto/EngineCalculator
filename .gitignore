# ============================================================================
# .gitignore - Engine Calculator v1.0.0
# Arquivo de exclusăo para Git - Evita commit de arquivos temporários
# ============================================================================

# ============================================================================
# VISUAL STUDIO
# ============================================================================

# User-specific files
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.VC.db
*.VC.VC.opendb

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Trace Files
*.e2e

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build Results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# Benchmark Results
BenchmarkDotNet.Artifacts/

# ============================================================================
# .NET / NUGET
# ============================================================================

# NuGet Packages
packages/
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# ============================================================================
# C++ COMPILED FILES
# ============================================================================

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# Intermediate files
*.ilk
*.pdb
*.exp
*.idb
*.ipdb
*.iobj
*.tlog

# ============================================================================
# WINDOWS
# ============================================================================

# Windows image file caches
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db

# Dump file
*.stackdump

# Folder config file
[Dd]esktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows Installer files
*.cab
*.msi
*.msix
*.msm
*.msp

# Windows shortcuts
*.lnk

# ============================================================================
# MACOS
# ============================================================================

.DS_Store
.AppleDouble
.LSOverride
._*

# ============================================================================
# INTELLIJ / JETBRAINS
# ============================================================================

.idea/
*.iml
*.ipr
*.iws

# ============================================================================
# VSCODE
# ============================================================================

.vscode/
*.code-workspace

# ============================================================================
# BACKUP / TEMPORARY FILES
# ============================================================================

# Backup files
*.bak
*.backup
*~
*_OLD_*
*_BACKUP_*
*_old
*.orig

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~
*.cache
*.log

# ============================================================================
# PROJECT SPECIFIC
# ============================================================================

# Dados de teste (năo versionar)
Data/test_*.json
Data/temp_*.json

# Configuraçőes locais do usuário
settings_local.json
user_preferences.json

# Relatórios temporários
reports/temp/
reports/*.tmp

# Scripts de build locais
build_local.bat
deploy_local.bat

# ============================================================================
# DOCUMENTATION TEMP FILES
# ============================================================================

# LaTeX temporary files
*.aux
*.lof
*.log
*.lot
*.fls
*.out
*.toc
*.fmt
*.fot
*.cb
*.cb2
*.lb

# Markdown preview
*.html (except in docs/html/)

# ============================================================================
# IDE SPECIFIC
# ============================================================================

# Rider
.idea/
*.sln.iml

# CLion
cmake-build-*/

# Eclipse
.cproject
.project
.settings/

# ============================================================================
# MISC
# ============================================================================

# Archives
*.zip
*.tar.gz
*.rar
*.7z

# Except release archives in releases/
!releases/*.zip

# Cores
core.*

# NodeJS (se usar ferramentas Node)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================================
# KEEP EMPTY DIRECTORIES
# ============================================================================
# Git năo versiona pastas vazias. Use arquivos .gitkeep se necessário.

!.gitkeep

# ============================================================================
# ALLOW SPECIFIC FILES
# ============================================================================

# Forçar inclusăo de arquivos importantes mesmo que matchem padrőes acima
!README.md
!LICENSE
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!.editorconfig

